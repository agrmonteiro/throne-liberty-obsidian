{
  "compilerOptions": {
    "composite":        true,
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2022"],
    "types":            ["electron-vite/node", "node"],
    "strict":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "resolveJsonModule": true
  },
  "include": ["electron.vite.config.*", "electron/**/*"]
}
