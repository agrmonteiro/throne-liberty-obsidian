{
  "compilerOptions": {
    "composite":        true,
    "target":           "ES2022",
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "jsx":              "react-jsx",
    "strict":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "baseUrl":          ".",
    "paths":            { "@/*": ["src/*"] }
  },
  "include": ["src/**/*", "src/**/*.d.ts"]
}
